{
  "name": "KUCCTHON Dev Container",
  "dockerFile": "Dockerfile",
  "context": "..",
  "postCreateCommand": "npm install && npm ci",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
    }
  },
  "remoteUser": "vscode"
}
